# RxScan AI — Backend Environment Variables
# Copy this file to .env and fill in your values
# .env is gitignored — never commit it

# ─── Server ──────────────────────────────────────────────────────────────────
ENVIRONMENT=development
PORT=8000

# ─── Translation (FREE — no registration needed) ─────────────────────────────
# Primary: Google Translate via deep-translator (unofficial, no key required)
# Fallback: MyMemory public API (1000 words/day free, also no key)
# Supported Indian langs: hi, bn, ta, te, mr, gu, kn, ml, pa, or, ur
TRANSLATION_PRIMARY=google          # Options: google | mymemory | deepl
TRANSLATION_FALLBACK=mymemory
TRANSLATION_TARGET_LANG=hi          # Default target language

# ─── Google Maps API (FREE — $200/month credit)
# Get at: https://console.cloud.google.com
# Enable: Places API, Geocoding API
GOOGLE_MAPS_API_KEY=

# ─── Firebase (FREE — Spark plan)
# Download service account JSON from Firebase Console
# Project Settings → Service Accounts → Generate new private key
FIREBASE_CREDENTIALS_PATH=./firebase-service-account.json
FIREBASE_PROJECT_ID=rxscan-ai

# ─── Model Configuration ──────────────────────────────────────────────────────
# Use 'large' for GPU, 'base' for CPU (faster but slightly less accurate)
TROCR_MODEL_SIZE=base    # Options: base | large

# ─── Limits ──────────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=15
MAX_LINES_PER_SCAN=30
